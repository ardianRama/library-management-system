# =========================
# Environment configuration
# =========================

# PostgreSQL (docker-compose.yml)
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password
POSTGRES_DB=your_database_name

# pgAdmin login (http://localhost:8081)
# You can change these if you want
PGADMIN_EMAIL=admin@library.com
PGADMIN_PASSWORD=admin

# Spring Boot database connection (application.properties)
# Must match POSTGRES_* values above
DB_USER=your_user
DB_PASS=your_password
DB_URL=jdbc:postgresql://localhost:5234/your_database_name