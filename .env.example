# =========================================================
# CREATE A .env FILE IN THE PROJECT ROOT
# =========================================================
# Create a .env file in the project root and replace
# the example values below with your own credentials.
#
# These variables are used by docker-compose.yml.

# PostgreSQL container configuration
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password
POSTGRES_DB=your_database_name

# pgAdmin login (http://localhost:8081)
# You can change these if you want
PGADMIN_EMAIL=admin@library.com
PGADMIN_PASSWORD=admin